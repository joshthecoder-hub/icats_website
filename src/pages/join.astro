---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { client } from "@/lib/sanity";
import { getStats } from "@/lib/content";
import { todayISO } from "@/lib/content";
import { formatDate } from "@/lib/format";
import { eventCategoryColours, eventCategoryLabels } from "@/lib/categories";

const [joinPage, programmes, upcomingEvents, stats] = await Promise.all([
  client.fetch<{
    heading?: string;
    intro?: string;
    ctaLabel?: string;
    ctaUrl?: string;
    ctaNote?: string;
  }>(`*[_type == "joinPage"][0]{ heading, intro, ctaLabel, ctaUrl, ctaNote }`),

  client.fetch<Array<{
    title: string;
    slug: { current: string };
    description?: string;
  }>>(`*[_type == "programme"] | order(sortOrder asc){ title, slug, description }`),

  client.fetch<Array<{
    title: string;
    date: string;
    time?: string;
    location?: string;
    category?: string;
  }>>(`*[_type == "event" && date >= $today] | order(date asc)[0...3]{ title, date, time, location, category }`, { today: todayISO() }),

  getStats(),
]);

const heading = joinPage?.heading || "Join ICATS";
const intro = joinPage?.intro || "";
const ctaLabel = joinPage?.ctaLabel || "Join via Imperial College Union";
const ctaUrl = joinPage?.ctaUrl || "#";
const ctaNote = joinPage?.ctaNote || "";
---

<BaseLayout
  title="Join ICATS"
  description="Join ICATS and become part of Imperial College's algorithmic trading community. Access competitions, courses, networking, and career opportunities in quant finance."
  canonical="/join"
>
  <div class="bg-brand-primary">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">

      <!-- Hero -->
      <div class="max-w-2xl mx-auto text-center">
        <h1 class="text-3xl sm:text-4xl font-bold text-brand-foreground">
          {heading}
        </h1>
        {intro && (
          <p class="mt-4 text-lg text-brand-foreground-muted leading-relaxed">
            {intro}
          </p>
        )}
      </div>

      <!-- Stats -->
      <div class="mt-12 grid grid-cols-3 gap-6 max-w-2xl mx-auto">
        {[
          { value: stats.members, label: "Members" },
          { value: stats.partners, label: "Industry Partners" },
          { value: stats.eventsHosted, label: "Events" },
        ].filter((s) => s.value).map((s) => (
          <div class="text-center">
            <div class="text-3xl font-bold text-brand-accent">{s.value}</div>
            <div class="text-sm text-brand-foreground-muted mt-1">{s.label}</div>
          </div>
        ))}
      </div>

      <!-- Programmes -->
      {programmes.length > 0 && (
        <div class="mt-16">
          <h2 class="text-2xl font-bold text-brand-foreground text-center">
            What You Get Access To
          </h2>
          <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {programmes.map((p) => (
              <a href={`/programmes/${p.slug.current}`} class="bg-white/5 border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-colors">
                <h3 class="font-bold text-brand-foreground">{p.title}</h3>
                {p.description && (
                  <p class="mt-2 text-sm text-brand-foreground-muted line-clamp-2">
                    {p.description}
                  </p>
                )}
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Upcoming Events -->
      {upcomingEvents.length > 0 && (
        <div class="mt-16">
          <h2 class="text-2xl font-bold text-brand-foreground text-center">
            Coming Up
          </h2>
          <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-4xl mx-auto">
            {upcomingEvents.map((e) => (
              <div class="bg-white/5 border border-white/10 rounded-xl p-6">
                {e.category && (
                  <span class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${eventCategoryColours[e.category] || "bg-gray-100 text-gray-700"}`}>
                    {eventCategoryLabels[e.category] || e.category}
                  </span>
                )}
                <h3 class="mt-2 font-bold text-brand-foreground">{e.title}</h3>
                <p class="mt-1 text-sm text-brand-foreground-muted">
                  {formatDate(e.date)}{e.time ? ` · ${e.time}` : ""}
                </p>
                {e.location && (
                  <p class="text-sm text-brand-foreground-muted">{e.location}</p>
                )}
              </div>
            ))}
          </div>
          <div class="mt-4 text-center">
            <a href="/events" class="text-sm font-medium text-brand-accent hover:underline">
              View all events &rarr;
            </a>
          </div>
        </div>
      )}

      <!-- CTA -->
      <div class="mt-16 text-center">
        <a
          href={ctaUrl}
          class="inline-block px-8 py-4 text-base font-semibold bg-brand-accent text-brand-primary rounded-lg hover:bg-amber-400 transition-colors"
        >
          {ctaLabel}
        </a>
        {ctaNote && (
          <p class="mt-3 text-sm text-brand-foreground-muted">
            {ctaNote}
          </p>
        )}
      </div>

    </div>
  </div>
</BaseLayout>
